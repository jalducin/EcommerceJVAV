# App
ENVIRONMENT=development
FRONTEND_URL=http://localhost:8000

# Base de datos
# SQLite para desarrollo (por defecto, no necesitas cambiarlo)
DATABASE_URL=sqlite+aiosqlite:///./metalshop.db
# PostgreSQL para producción:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/metalshop

# JWT — genera tu secret con: openssl rand -hex 32
SECRET_KEY=cambia-esto-en-produccion
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email (opcional en desarrollo)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASSWORD=tu-app-password
EMAILS_FROM=noreply@metalshop.com
