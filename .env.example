# ============================================================
# MetalShop — Variables de Entorno
# Copia este archivo como .env y ajusta los valores:
#   cp .env.example .env
# ============================================================

# Entorno: development | production
ENVIRONMENT=development

# URL pública del frontend (usada para CORS)
FRONTEND_URL=http://localhost:8000

# ── Base de datos ─────────────────────────────────────────
# SQLite (default, listo para desarrollo local sin configuración):
DATABASE_URL=sqlite+aiosqlite:///./metalshop.db

# PostgreSQL (para Docker Compose o producción):
# DATABASE_URL=postgresql+asyncpg://metalshop:metalshop@db:5432/metalshop

# ── JWT ───────────────────────────────────────────────────
# Genera una clave segura con: openssl rand -hex 32
SECRET_KEY=cambia-esto-en-produccion-usa-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Email (opcional en desarrollo) ───────────────────────
# Dejar vacíos para deshabilitar el envío de emails en dev.
# En producción usar credenciales SMTP reales.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASSWORD=tu-app-password
EMAILS_FROM=noreply@metalshop.com

Tienda: https://d3rw1q49m6mvnq.cloudfront.net
Panel admin: https://d3rw1q49m6mvnq.cloudfront.net/admin/dashboard.html
API + Swagger: https://cizs8fa7lf.execute-api.us-east-2.amazonaws.com/dev/api/docs
Admin: admin@metalshop.mx / Admin123! · Cliente: cliente@metalshop.mx / Cliente123!
